TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
LOG_LEVEL=INFO
CRYPTOPANIC_TOKEN=
COINALYZE_COOLDOWN_SECONDS=1.5
SINGLE_SOURCE_PENALTY=8
PAIR_FETCH_DELAY_SECONDS=1.5

SCAN_PAIRS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,SUIUSDT,DOGEUSDT,RAVEUSDT,HYPEUSDT,ZECUSDT
KLINE_INTERVAL=15m
HIGHER_TF_INTERVAL=1h
KLINES_LIMIT=250
SCAN_INTERVAL_SECONDS=300
PRIORITIZE_HIGH_VOLUME=true
HIGH_VOLUME_SCAN_LIMIT=0

MIN_CONFIDENCE=70
MAX_SIGNALS_PER_DAY=3
MAX_SIGNALS_PER_CYCLE=1
MIN_CONFIDENCE_FLOOR=70

CAPITAL_USDT=6000
RISK_PER_TRADE=0.01

VOLUME_SPIKE_FACTOR=1.5
LEVEL_PROXIMITY_ATR_FACTOR=0.35
NEARBY_BLOCK_ATR_FACTOR=1.2

FUNDING_NEUTRAL_ABS=0.0001
STRONG_SPIKE_ATR_MULT=3.0
MIN_OI_CHANGE_PCT=0.2
REQUIRE_NON_ZERO_DERIVATIVES=true
MIN_ADX=18
MIN_EMA_GAP_RATIO=0.0025
MIN_HTF_EMA_GAP_RATIO=0.0020
MIN_REJECTION_WICK_RATIO=0.35
MAX_EXTENSION_ATR=1.2

# Fear & Greed: reject BUY signals when market is in extreme fear (< 20)
FEAR_GREED_MIN_LONG=20
# Fear & Greed: reject SELL signals when market is in extreme greed (> 80)
FEAR_GREED_MAX_SHORT=80
EXTREME_FEAR_THRESHOLD=25
EXTREME_FEAR_LONG_PENALTY=10
EXTREME_FEAR_SHORT_BOOST=5
# For BUY, top traders should not be heavily short
MIN_TOP_TRADER_LS_LONG=0.9
# For SELL, top traders should not be heavily long
MAX_TOP_TRADER_LS_SHORT=1.1
MIN_TAKER_BUY_SELL_LONG=1.02
# For SELL, require taker sell pressure
MAX_TAKER_BUY_SELL_SHORT=0.98

ECONOMIC_EVENT_LOOKAHEAD_HOURS=2
CAUTION_MODE_POSITION_SCALE=0.5

# Coinalyze integration
COINALYZE_API_KEY=your_coinalyze_api_key_here
MIN_COINALYZE_AGG_OI_LONG=0.10
FAST_TRACK_CANDLE_MOVE_PCT=1.2
FAST_TRACK_VOLUME_MULT=1.8
BREAKOUT_CONFLUENCE_BOOST=12
COINALYZE_SHORT_LIQ_SPIKE_1H_USD=15000000
MAX_COINALYZE_AGG_OI_SHORT=-0.05
MIN_COINALYZE_LS_LONG=1.0
MAX_COINALYZE_LS_SHORT=1.0
MAX_PREDICTED_FUNDING_FOR_LONG=0.0005
MIN_PREDICTED_FUNDING_FOR_SHORT=-0.0005
COINALYZE_OI_DIVERGENCE_PENALTY=10
COINALYZE_LIQUIDATION_SPIKE_1H_USD=50000000

SQLITE_DB_PATH=signals.db

BACKTEST_PAIR=BTCUSDT
BACKTEST_BARS=1200
BACKTEST_LOOKAHEAD_BARS=24
BACKTEST_ALL_PAIRS=false

OPTIMIZE_BARS=1200
OPTIMIZE_LOOKAHEAD_BARS=24
OPTIMIZE_TOP_N=10
OPTIMIZE_EXPORT_CSV=backtests/optimization_top.csv
OPTIMIZE_AUTO_APPLY_BEST=false
OPTIMIZE_APPLY_ENV_PATH=.env

# Optional CLI override examples:
# --export-csv backtests/btc_backtest.csv
# --export-csv-dir backtests/
